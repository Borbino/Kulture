{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/autonomous-discovery",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/emerging-trend-scan",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/vip-monitoring",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/trend-detection",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/newsletter/send",
      "schedule": "0 9 * * 1,4"
    },
    {
      "path": "/api/cron/self-maintenance",
      "schedule": "0 0 * * 0"
    }
  ],
  "env": {
    "NEXT_PUBLIC_SANITY_DATASET": "production"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/monitoring",
      "permanent": false
    }
  ]
}

