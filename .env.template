# 환경변수 설정 예시
# 이 파일을 복사하여 .env.local로 만들고 실제 값을 입력하세요
# 사용법: cp .env.template .env.local

# ============================================================
# 1. 핵심 인프라 (필수)
# ============================================================

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_admin_token_here

# 사이트 도메인 (SSoT — 반드시 설정)
NEXT_PUBLIC_SITE_URL=https://www.kulture.wiki

# NextAuth 인증 (필수)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-characters-long

# Cron Job 보안 (32자 이상 랜덤 문자열)
CRON_SECRET=your_secure_random_string_here

# ============================================================
# 2. AI / 콘텐츠 생성
# ============================================================

# OpenAI API (콘텐츠 생성 - 필수)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_KEY_BACKUP=your_openai_backup_key_here

# Google Gemini AI (트렌드 필터링용)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# OpenRouter API (멀티모델 라우팅용)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# HuggingFace API (NLP 분석용)
# 주의: 코드 내에서 HUGGINGFACE_API_KEY와 HUGGINGFACE_API_TOKEN 혼용 — 둘 다 설정
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_API_TOKEN=your_huggingface_api_key_here

# ============================================================
# 3. 번역 API
# ============================================================

# DeepL 번역 (프리미엄 번역용)
DEEPL_API_KEY=your_deepl_api_key_here
DEEPL_API_KEY_BACKUP=your_deepl_backup_key_here

# Google 번역 API
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
GOOGLE_TRANSLATE_API_KEY_BACKUP=your_google_translate_backup_key_here

# 번역 비용 예산 (USD)
TRANSLATION_BUDGET_MONTHLY=1000
TRANSLATION_BUDGET_DAILY=50

# ============================================================
# 4. SNS 자동 포스팅
# ============================================================

# Twitter/X API (읽기 전용 — 트렌드 수집)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Twitter/X API (읽기+쓰기 — 자동 포스팅용, X Developer Portal에서 발급)
X_API_KEY=your_x_app_key_here
X_API_SECRET=your_x_app_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_SECRET=your_x_access_token_secret_here

# Facebook Graph API (자동 포스팅용)
FB_PAGE_ID=your_facebook_page_id_here
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Instagram (선택)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# TikTok (선택)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# ============================================================
# 5. 콘텐츠 수집 API
# ============================================================

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Naver API
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# RapidAPI (다수의 외부 API 통합)
RAPIDAPI_KEY=your_rapidapi_key_here

# ============================================================
# 6. 인프라 / 데이터베이스
# ============================================================

# Redis (번역 캐시, 세션 저장)
REDIS_URL=redis://localhost:6379

# MongoDB (선택 — 일부 모듈에서 사용)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=kulture
MONGODB_DB_NAME=kulture

# ============================================================
# 7. 알림 / 이메일
# ============================================================

# SendGrid 이메일 API
EMAIL_API_KEY=your_sendgrid_api_key_here

# 이메일 발신자 주소
EMAIL_FROM=noreply@kulture.wiki

# Slack 웹훅 (운영 알림용)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ============================================================
# 8. 관리자 / 보안
# ============================================================

# 관리자 이메일 (단수 — notificationSystem.js 사용)
ADMIN_EMAIL=your_admin_email@example.com

# 관리자 이메일 목록 (복수 쉼표 구분 — verifyAdmin() 사용)
ADMIN_EMAILS=your_admin_email@example.com

# 관리자 페이지 접근 비밀번호
NEXT_PUBLIC_ADMIN_PASSWORD=kulture2025

# Google Analytics 측정 ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense (선택)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# 이미지 생성 기능 활성화 여부 (true/false)
ENABLE_IMAGE_GENERATION=false

# ============================================================
# 9. OAuth 로그인 (선택)
# ============================================================

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret


# ============================================================
# 10. 수익화 (Revenue Engine)
# ============================================================

# Google AdSense 퍼블리셔 ID (형식: pub-XXXXXXXXXXXXXXXX)
ADSENSE_PUBLISHER_ID=pub-xxxxxxxxxxxxxxxx

# AdSense 광고 슬롯 ID
ADSENSE_SLOT_HEADER=xxxxxxxxxx
ADSENSE_SLOT_INCONTENT=xxxxxxxxxx
ADSENSE_SLOT_FOOTER=xxxxxxxxxx

# Coupang Partners 제휴 (한국 K-상품 커미션 5-12%)
# https://partners.coupang.com 에서 발급
COUPANG_AFFILIATE_ID=your-coupang-affiliate-id
COUPANG_TRACKING_CODE=your-coupang-tracking-code

# Amazon Associates 제휴 (글로벌 K-상품 커미션 3-10%)
# https://affiliate-program.amazon.com 에서 발급
AMAZON_TRACKING_ID=kulture-20
AMAZON_DEFAULT_TAG=kulture-20

# ============================================================
# 11. 신규 소셜 미디어 플랫폼
# ============================================================

# VK.com (러시아·동유럽 K-Pop 팬 모니터링, 무료)
# https://vk.com/dev 에서 발급
VK_ACCESS_TOKEN=your-vk-access-token

# Mastodon (ActivityPub, API 키 불필요 — 공개 인스턴스 사용 시 필요 없음)
# 인증된 게시가 필요한 경우만 설정
MASTODON_ACCESS_TOKEN=

# ============================================================
# 12. 이머징 트렌드 탐지 설정
# ============================================================

# 이머징 트렌드 자동 추적 최소 벨로시티 점수 (기본: 50)
EMERGING_TREND_AUTO_TRACK_THRESHOLD=50

# 이머징 트렌드 관리자 알림 최소 벨로시티 점수 (기본: 100)
EMERGING_TREND_ALERT_THRESHOLD=100

# ============================================================
# 13. 프리미엄 멤버십 — Stripe
# ============================================================

# Stripe 비밀 키 (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key

# Stripe 공개 키 (프론트엔드)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# Stripe 웹훅 서명 시크릿 (Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe 상품 가격 ID (Dashboard에서 생성)
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_ANNUAL=price_annual_id
STRIPE_PRICE_LIFETIME=price_lifetime_id

# ============================================================
# 14. 프리미엄 멤버십 — Toss Payments (한국)
# ============================================================

# Toss Payments (https://developers.tosspayments.com)
TOSS_SECRET_KEY=test_sk_your-toss-secret-key
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_your-toss-client-key

# ============================================================
# 15. 뉴스레터 + 이메일 설정
# ============================================================

# 발신 이메일 주소
EMAIL_FROM=newsletter@kulture.wiki
EMAIL_FROM_NAME=Kulture Newsletter

# SendGrid API 키 (무료: 100이메일/일, https://sendgrid.com)
EMAIL_API_KEY=SG.your-sendgrid-api-key

# ============================================================
# 16. 데이터 라이선싱 B2B
# ============================================================

# B2B 문의 이메일
B2B_CONTACT_EMAIL=b2b@kulture.wiki

# ============================================================
# 17. Redis 캐시 — Upstash (서버리스 호환)
# ============================================================

# Upstash Redis REST API (무료: https://upstash.com)
# 서버리스 환경에서 TCP 연결 없이 HTTP REST로 캐시 접근
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# 알림 쿨다운 (같은 이벤트 재발송 최소 간격, ms, 기본 5분)
ALERT_MIN_INTERVAL_MS=300000

# ============================================================
# 18. 운영 알림 — Slack / Discord 웹훅
# ============================================================

# Slack Incoming Webhook (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXX

# Discord Webhook (서버 설정 > 연동 > 웹훅)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000000000/XXXXXXXXXXXX

# ============================================================
# 19. 서비스 기본 URL (SEO, Sitemap, OG 이미지에 사용)
# ============================================================

# 배포된 사이트 URL (끝에 / 없이)
NEXT_PUBLIC_SITE_URL=https://kulture.app
