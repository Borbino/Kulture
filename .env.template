# 환경변수 설정 예시
# 이 파일을 복사하여 .env.local로 만들고 실제 값을 입력하세요
# 사용법: cp .env.template .env.local

# ============================================================
# 1. 핵심 인프라 (필수)
# ============================================================

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_admin_token_here

# 사이트 도메인 (SSoT — 반드시 설정)
NEXT_PUBLIC_SITE_URL=https://www.kulture.wiki

# NextAuth 인증 (필수)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-characters-long

# Cron Job 보안 (32자 이상 랜덤 문자열)
CRON_SECRET=your_secure_random_string_here

# ============================================================
# 2. AI / 콘텐츠 생성
# ============================================================

# OpenAI API (콘텐츠 생성 - 필수)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_KEY_BACKUP=your_openai_backup_key_here

# Google Gemini AI (트렌드 필터링용)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# OpenRouter API (멀티모델 라우팅용)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# HuggingFace API (NLP 분석용)
# 주의: 코드 내에서 HUGGINGFACE_API_KEY와 HUGGINGFACE_API_TOKEN 혼용 — 둘 다 설정
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_API_TOKEN=your_huggingface_api_key_here

# ============================================================
# 3. 번역 API
# ============================================================

# DeepL 번역 (프리미엄 번역용)
DEEPL_API_KEY=your_deepl_api_key_here
DEEPL_API_KEY_BACKUP=your_deepl_backup_key_here

# Google 번역 API
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
GOOGLE_TRANSLATE_API_KEY_BACKUP=your_google_translate_backup_key_here

# 번역 비용 예산 (USD)
TRANSLATION_BUDGET_MONTHLY=1000
TRANSLATION_BUDGET_DAILY=50

# ============================================================
# 4. SNS 자동 포스팅
# ============================================================

# Twitter/X API (읽기 전용 — 트렌드 수집)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Twitter/X API (읽기+쓰기 — 자동 포스팅용, X Developer Portal에서 발급)
X_API_KEY=your_x_app_key_here
X_API_SECRET=your_x_app_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_SECRET=your_x_access_token_secret_here

# Facebook Graph API (자동 포스팅용)
FB_PAGE_ID=your_facebook_page_id_here
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Instagram (선택)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# TikTok (선택)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# ============================================================
# 5. 콘텐츠 수집 API
# ============================================================

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Naver API
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# RapidAPI (다수의 외부 API 통합)
RAPIDAPI_KEY=your_rapidapi_key_here

# ============================================================
# 6. 인프라 / 데이터베이스
# ============================================================

# Redis (번역 캐시, 세션 저장)
REDIS_URL=redis://localhost:6379

# MongoDB (선택 — 일부 모듈에서 사용)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=kulture
MONGODB_DB_NAME=kulture

# ============================================================
# 7. 알림 / 이메일
# ============================================================

# SendGrid 이메일 API
EMAIL_API_KEY=your_sendgrid_api_key_here

# 이메일 발신자 주소
EMAIL_FROM=noreply@kulture.wiki

# Slack 웹훅 (운영 알림용)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ============================================================
# 8. 관리자 / 보안
# ============================================================

# 관리자 이메일 (단수 — notificationSystem.js 사용)
ADMIN_EMAIL=your_admin_email@example.com

# 관리자 이메일 목록 (복수 쉼표 구분 — verifyAdmin() 사용)
ADMIN_EMAILS=your_admin_email@example.com

# 관리자 페이지 접근 비밀번호
NEXT_PUBLIC_ADMIN_PASSWORD=kulture2025

# Google Analytics 측정 ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense (선택)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# 이미지 생성 기능 활성화 여부 (true/false)
ENABLE_IMAGE_GENERATION=false

# ============================================================
# 9. OAuth 로그인 (선택)
# ============================================================

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

